{
  "name": "eforge-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eforge-build/eforge.git"
  },
  "homepage": "https://eforge.build",
  "scripts": {
    "build": "pnpm -r build",
    "build:ui": "pnpm --filter @eforge-build/monitor-ui build",
    "dev:monitor": "pnpm --filter @eforge-build/monitor-ui dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "pnpm -r type-check",
    "prepublishOnly": "pnpm build && pnpm test",
    "prepare:pi-package-publish": "node ./scripts/prepare-pi-package-publish.mjs"
  },
  "packageManager": "pnpm@10.26.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eforge-build/client": "workspace:*",
    "@eforge-build/engine": "workspace:*",
    "@eforge-build/monitor": "workspace:*",
    "@eforge-build/monitor-ui": "workspace:*",
    "@mariozechner/pi-agent-core": "^0.63.2",
    "@mariozechner/pi-ai": "^0.63.2",
    "@mariozechner/pi-coding-agent": "^0.63.2",
    "@types/node": "^25.5.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "yaml": "^2.8.3"
  }
}
